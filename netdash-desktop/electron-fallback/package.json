{
  "name": "netdash-desktop-electron-fallback",
  "description": "NET Control Center Electron fallback shell",
  "version": "0.1.0",
  "author": "NetTransit",
  "private": true,
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dist": "npm run build && electron-builder --win portable --x64",
    "dist:portable": "npm run build && electron-builder --win portable --x64",
    "dist:installer": "npm run build && electron-builder --win nsis --x64",
    "dist:both": "npm run build && electron-builder --win nsis portable --x64",
    "build:win": "npm run dist:both",
    "pack": "npm run build && electron-builder --dir --win --x64",
    "dev": "npm run build && electron .",
    "start": "electron ."
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.16.0",
    "electron": "^34.0.2",
    "electron-builder": "^26.0.14",
    "typescript": "^5.6.2"
  },
  "build": {
    "appId": "com.netransit.net-control-center",
    "productName": "NET Control Center",
    "artifactName": "NET-Control-Center-${version}.${ext}",
    "directories": {
      "output": "dist/out",
      "buildResources": "../icons"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "../icons/icon.ico"
    },
    "nsis": {
      "artifactName": "NET-Control-Center-Setup-${version}.${ext}",
      "installerIcon": "../icons/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "NET-Control-Center-Portable-${version}.${ext}"
    }
  }
}
